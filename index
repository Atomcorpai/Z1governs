<script>
// ── Gate logic (mirrors z1_action_guard.py) ──────────────────────────────────
const DESTRUCTIVE = ['delete','remove','wipe','erase','destroy','purge','trash','overwrite','replace','reset','format','drop table','truncate'];
const EVIDENCE    = ['edit evidence','alter evidence','modify evidence','change evidence','redact original','rename original','delete original','overwrite original'];
const EXTERNAL    = ['send','submit','file','publish','post','email','forward','upload','commit','push','merge','deploy','release'];
const AMBIGUOUS   = ['clean up everything','fix everything','remove everything','archive everything','update everything','sync everything','delete everything','handle everything','handle it','deal with it','sort it out','take care of it'];
const SAFE        = ['draft','review','summarize','analyze','inspect','compare','explain','classify','triage','recommend','make a checklist'];

function normalize(t) { return (t||'').toLowerCase().replace(/\s+/g,' ').trim(); }
function matchAny(t,terms) { return terms.filter(term => t.includes(term)); }

function classify(instruction) {
  const t = normalize(instruction);
  if (!t) return {verdict:'STOP_FOR_CLARITY',reason:'Empty instruction.',risk:'unknown'};
  const ambig = matchAny(t, AMBIGUOUS);
  if (ambig.length) return {verdict:'STOP_FOR_CLARITY',reason:`Ambiguous scope — "${ambig[0]}" without a specific target.`,risk:'ambiguous'};
  const evid = matchAny(t, EVIDENCE);
  if (evid.length) return {verdict:'BLOCK',reason:`Evidence-affecting action requires explicit confirmation. Matched: ${evid.join(', ')}.`,risk:'high'};
  const dest = matchAny(t, DESTRUCTIVE);
  if (dest.length) return {verdict:'BLOCK',reason:`Destructive or irreversible action requires explicit confirmation. Matched: ${dest.join(', ')}.`,risk:'high'};
  const ext = matchAny(t, EXTERNAL);
  if (ext.length) return {verdict:'BLOCK',reason:`External action (${ext.join(', ')}) requires explicit confirmation before execution.`,risk:'medium'};
  const safe = matchAny(t, SAFE);
  if (safe.length) return {verdict:'ALLOW',reason:`Safe, reversible analysis or drafting request. Matched: ${safe.join(', ')}.`,risk:'low'};
  return {verdict:'ALLOW',reason:'No destructive, evidence-affecting, external, or ambiguous trigger detected.',risk:'low'};
}

// ── HMAC-SHA256 seal (WebCrypto) ─────────────────────────────────────────────
const SESSION_KEY = crypto.getRandomValues(new Uint8Array(32));
let cryptoKey = null;

async function getKey() {
  if (!cryptoKey) {
    cryptoKey = await crypto.subtle.importKey('raw', SESSION_KEY, {name:'HMAC',hash:'SHA-256'}, false, ['sign','verify']);
  }
  return cryptoKey;
}

async function signInstruction(instruction, ts) {
  const key = await getKey();
  const payload = JSON.stringify({instruction, ts});
  const sig = await crypto.subtle.sign('HMAC', key, new TextEncoder().encode(payload));
  return Array.from(new Uint8Array(sig)).map(b=>b.toString(16).padStart(2,'0')).join('').slice(0,8);
}

async function verifyInstruction(instruction, ts, expectedSig) {
  const key = await getKey();
  const payload = JSON.stringify({instruction, ts});
  const sig = await crypto.subtle.sign('HMAC', key, new TextEncoder().encode(payload));
  const actual = Array.from(new Uint8Array(sig)).map(b=>b.toString(16).padStart(2,'0')).join('').slice(0,8);
  return actual === expectedSig;
}

// ── Ledger ───────────────────────────────────────────────────────────────────
let ledgerEntries = [];
try { ledgerEntries = JSON.parse(localStorage.getItem('z1_ledger') || '[]'); } catch(e) {}

function saveLedger() {
  try { localStorage.setItem('z1_ledger', JSON.stringify(ledgerEntries.slice(-200))); } catch(e) {}
}

function formatTs(iso) {
  return iso.replace('T',' ').replace(/\.\d+Z$/,' UTC').replace('Z',' UTC');
}

function renderLedger() {
  const rows = document.getElementById('ledger-rows');
  const allowed = ledgerEntries.filter(e=>e.verdict==='ALLOW').length;
  const blocked = ledgerEntries.filter(e=>e.verdict!=='ALLOW').length;
  document.getElementById('tally-allowed').textContent = allowed + ' ALLOWED';
  document.getElementById('tally-blocked').textContent = blocked + ' BLOCKED';

  if (!ledgerEntries.length) {
    rows.innerHTML = '<div style="padding:1rem 1rem;font-family:var(--mono);font-size:0.75rem;color:var(--text-3);">No entries yet. Try the simulator above.</div>';
    return;
  }

  rows.innerHTML = [...ledgerEntries].reverse().map(e => {
    const badgeClass = e.verdict==='ALLOW' ? 'badge-allow' : e.verdict==='BLOCK' ? 'badge-block' : 'badge-stop';
    const sealClass  = e.verdict==='ALLOW' ? 'ledger-seal-allow' : 'ledger-seal-block';
    const sealText   = e.verdict==='ALLOW'
      ? `VERIFIED <span style="color:var(--text-3)">${e.seal}...✓</span>`
      : `REJECTED <span style="color:var(--text-3)">${e.seal}...✗</span>`;
    return `<div class="ledger-row">
      <span class="ledger-ts">${formatTs(e.ts)}</span>
      <span class="ledger-cmd">${e.instruction.slice(0,60)}</span>
      <span><span class="verdict-badge ${badgeClass}">${e.verdict}</span></span>
      <span class="${sealClass}">${sealText}</span>
    </div>`;
  }).join('');
}

function clearLedger() {
  ledgerEntries = [];
  saveLedger();
  renderLedger();
}

// ── Simulator ────────────────────────────────────────────────────────────────
function fillSim(btn) {
  document.getElementById('sim-input').value = btn.textContent;
  document.getElementById('sim-input').focus();
}

async function runGate(e) {
  e.preventDefault();
  const instruction = document.getElementById('sim-input').value.trim();
  if (!instruction) return;

  const result = classify(instruction);
  const ts = new Date().toISOString();
  const seal = await signInstruction(instruction, ts);
  const verified = result.verdict === 'ALLOW' ? await verifyInstruction(instruction, ts, seal) : false;

  // Add to ledger
  ledgerEntries.push({instruction, verdict: result.verdict, ts, seal, verified});
  saveLedger();
  renderLedger();

  // Show inline result
  const verdictClass = result.verdict==='ALLOW' ? 'verdict-allow' : result.verdict==='BLOCK' ? 'verdict-block' : 'verdict-stop';
  const sealLine = result.verdict==='ALLOW'
    ? `<span style="color:var(--green)">SEAL VERIFIED</span> <span style="color:var(--text-3)">${seal}...✓</span>`
    : `<span style="color:var(--red)">SEAL REJECTED</span> <span style="color:var(--text-3)">${seal}...✗</span>`;

  document.getElementById('sim-result-box').innerHTML =
    `<span class="${verdictClass}">${result.verdict}</span> — ${result.reason}<br><br>${sealLine}`;
  document.getElementById('sim-result').classList.add('visible');
}

// ── Init ─────────────────────────────────────────────────────────────────────
renderLedger();
</script>
