    <script>
      // Funnel analytics tracking for landing pages with cross-site visitor identification
      (function() {
        const appId = window.__APP_ID__;
        if (!appId) return;
        
        const SESSION_KEY = 'funnel_session_id';
        const CONTACT_KEY = 'funnel_contact_id';
        const VISITOR_COOKIE = 'audos_vid';
        var storageAvailable = true;
        var inMemorySessionId = null;
        var inMemoryContactId = null;
        
        // Check if sessionStorage is available
        try {
          sessionStorage.setItem('__test__', '1');
          sessionStorage.removeItem('__test__');
        } catch (e) {
          storageAvailable = false;
          console.warn('[Funnel] sessionStorage not available, using in-memory fallback');
        }
        
        // Comprehensive list of second-level TLDs (country-code SLDs) that require 3-part domain
        var MULTI_LEVEL_TLDS = [
          // UK
          'co.uk', 'org.uk', 'me.uk', 'net.uk', 'ac.uk', 'gov.uk', 'ltd.uk', 'plc.uk', 'sch.uk',
          // Anguilla (.ai is treated as standard TLD but some registrars use second-level)
          'com.ai', 'net.ai', 'org.ai', 'off.ai',
          // Australia  
          'com.au', 'net.au', 'org.au', 'edu.au', 'gov.au', 'asn.au', 'id.au',
          // New Zealand
          'co.nz', 'net.nz', 'org.nz', 'govt.nz', 'ac.nz', 'school.nz', 'geek.nz', 'gen.nz',
          // Brazil
          'com.br', 'net.br', 'org.br', 'gov.br', 'edu.br', 'art.br', 'blog.br',
          // Japan
          'co.jp', 'or.jp', 'ne.jp', 'ac.jp', 'ad.jp', 'ed.jp', 'go.jp', 'gr.jp',
          // India
          'co.in', 'net.in', 'org.in', 'gen.in', 'firm.in', 'ind.in',
          // Singapore
          'com.sg', 'net.sg', 'org.sg', 'edu.sg', 'gov.sg', 'per.sg',
          // South Africa
          'co.za', 'org.za', 'web.za', 'net.za', 'gov.za',
          // Mexico
          'com.mx', 'org.mx', 'gob.mx', 'edu.mx', 'net.mx',
          // South Korea
          'co.kr', 'or.kr', 'ne.kr', 'ac.kr', 'go.kr',
          // Hong Kong
          'com.hk', 'org.hk', 'net.hk', 'edu.hk', 'gov.hk',
          // Taiwan
          'com.tw', 'org.tw', 'net.tw', 'edu.tw', 'gov.tw',
          // China
          'com.cn', 'net.cn', 'org.cn', 'gov.cn', 'ac.cn', 'edu.cn',
          // Germany (special)
          'co.de',
          // USA state-level
          'co.us', 'k12.us', 'ci.us', 'state.us',
          // Other common ones
          'com.tr', 'org.tr', 'net.tr', 'biz.tr', 'gov.tr',
          'co.il', 'org.il', 'net.il', 'ac.il', 'gov.il',
          'com.ar', 'org.ar', 'net.ar', 'gov.ar',
          'com.pl', 'org.pl', 'net.pl', 'gov.pl',
          'com.pt', 'org.pt', 'net.pt', 'gov.pt',
          'co.id', 'or.id', 'go.id', 'ac.id', 'sch.id',
          'co.th', 'or.th', 'ac.th', 'go.th',
          'com.ph', 'org.ph', 'net.ph', 'gov.ph',
          'com.my', 'org.my', 'net.my', 'gov.my', 'edu.my',
          'com.vn', 'net.vn', 'org.vn', 'gov.vn', 'edu.vn',
          // Platform/hosting domains in Public Suffix List (browsers block cookies on root)
          'replit.dev', 'replit.app', 'repl.co',
          'github.io', 'herokuapp.com', 'netlify.app', 'vercel.app',
          'pages.dev', 'workers.dev', 'web.app', 'firebaseapp.com',
          'azurewebsites.net', 'cloudfront.net', 'amazonaws.com',
          'ngrok.io', 'ngrok.app', 'railway.app', 'render.com',
          'fly.dev', 'deno.dev', 'glitch.me'
        ];
        
        // Get or create visitor ID from cookie (persists across sessions and sites)
        function getVisitorId() {
          var cookies = document.cookie.split(';');
          for (var i = 0; i < cookies.length; i++) {
            var cookie = cookies[i].trim();
            if (cookie.startsWith(VISITOR_COOKIE + '=')) {
              return cookie.substring(VISITOR_COOKIE.length + 1);
            }
          }
          // Create new visitor ID and set cookie for 1 year
          var visitorId = 'vid_' + Date.now() + '_' + Math.random().toString(36).substring(2, 15);
          var expires = new Date();
          expires.setFullYear(expires.getFullYear() + 1);
          
          // Determine cookie domain for cross-subdomain tracking
          var hostname = window.location.hostname;
          var cookieDomain = '';
          
          // Platform domains where we should NOT set a cross-subdomain cookie
          // Safari ITP blocks JavaScript-set cookies with domain attributes on public suffix domains
          var PLATFORM_DOMAINS = [
            'replit.dev', 'replit.app', 'repl.co',
            'github.io', 'herokuapp.com', 'netlify.app', 'vercel.app',
            'pages.dev', 'workers.dev', 'web.app', 'firebaseapp.com',
            'azurewebsites.net', 'cloudfront.net', 'amazonaws.com',
            'ngrok.io', 'ngrok.app', 'railway.app', 'render.com',
            'fly.dev', 'deno.dev', 'glitch.me'
          ];
          
          function isPlatformDomain(host) {
            for (var i = 0; i < PLATFORM_DOMAINS.length; i++) {
              if (host.endsWith('.' + PLATFORM_DOMAINS[i]) || host === PLATFORM_DOMAINS[i]) {
                return true;
              }
            }
            return false;
          }
          
          // Skip domain for localhost, IP addresses, AND platform domains
          var isLocalhost = hostname === 'localhost' || hostname === '127.0.0.1' || hostname.endsWith('.localhost');
          var isIP = /^\d+\.\d+\.\d+\.\d+$/.test(hostname);
          var isPlatform = isPlatformDomain(hostname);
          
          // For platform domains (like replit.dev), DON'T set a domain - use host-only cookie
          if (!isLocalhost && !isIP && !isPlatform) {
            var domainParts = hostname.split('.');
            var lastTwo = domainParts.slice(-2).join('.');
            
            // Check if this is a multi-level TLD requiring 3-part domain
            if (MULTI_LEVEL_TLDS.indexOf(lastTwo) !== -1 && domainParts.length >= 3) {
              cookieDomain = '; domain=.' + domainParts.slice(-3).join('.');
            } else if (domainParts.length >= 2) {
              // For standard TLDs like example.com, example.io, example.app
              cookieDomain = '; domain=.' + domainParts.slice(-2).join('.');
            }
          }
          
          // Set cookie with SameSite=Lax for Safari ITP compatibility
          // Safari blocks SameSite=None cookies set via JavaScript on public suffix domains
          var isSecure = window.location.protocol === 'https:';
          var secureFlag = isSecure ? '; Secure' : '';
          var writeCookie = function() {
            document.cookie = VISITOR_COOKIE + '=' + visitorId + '; expires=' + expires.toUTCString() + '; path=/' + cookieDomain + '; SameSite=Lax' + secureFlag;
            console.log('[Funnel] Created new visitor ID:', visitorId, 'domain:', cookieDomain || 'current');
          };
          if (window.__GDPR_ENABLED__ && window.__audosConsent && typeof window.__audosConsent.onAnalytics === 'function') {
            window.__audosConsent.onAnalytics(writeCookie);
            console.log('[Funnel] Deferred visitor cookie write until analytics consent');
          } else {
            writeCookie();
          }
          return visitorId;
        }
        
        // Initialize visitor ID on page load
        var visitorId = getVisitorId();
        window.__VISITOR_ID__ = visitorId;
        
        // Get or create session ID with fallback for blocked storage
        function getSessionId() {
          if (!storageAvailable) {
            if (!inMemorySessionId) {
              inMemorySessionId = 'session_' + Date.now() + '_' + Math.random().toString(36).substring(7);
            }
            return inMemorySessionId;
          }
          var sessionId = sessionStorage.getItem(SESSION_KEY);
          if (!sessionId) {
            sessionId = 'session_' + Date.now() + '_' + Math.random().toString(36).substring(7);
            sessionStorage.setItem(SESSION_KEY, sessionId);
          }
          return sessionId;
        }
        
        // Update session ID (when server returns a new one)
        function setSessionId(newSessionId) {
          if (storageAvailable) {
            sessionStorage.setItem(SESSION_KEY, newSessionId);
          }
          inMemorySessionId = newSessionId;
        }
        
        // Get contact ID (for event association)
        function getContactId() {
          if (!storageAvailable) return inMemoryContactId;
          return sessionStorage.getItem(CONTACT_KEY) || inMemoryContactId;
        }
        
        // Set contact ID
        function setContactId(contactId) {
          if (storageAvailable) {
            sessionStorage.setItem(CONTACT_KEY, contactId);
          }
          inMemoryContactId = contactId;
        }
        
        // Track funnel event (now includes visitorId) - returns promise with eventId
        function trackEvent(eventType, metadata, callback) {
          return fetch('/api/landing/' + appId + '/track', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              eventType: eventType,
              sessionId: getSessionId(),
              visitorId: visitorId,
              contactId: getContactId(),
              userAgent: navigator.userAgent,
              referrer: document.referrer || undefined,
              metadata: metadata || {},
              attribution: getAttribution()
            })
          }).then(function(r) { return r.json(); }).then(function(data) {
            if (callback) callback(null, data);
            return data;
          }).catch(function(err) { 
            console.warn('[Funnel] Failed to track:', err);
            if (callback) callback(err);
          });
        }
        
        // Cross-subdomain attribution via root-domain-scoped cookie
        // sessionStorage is per-origin so www. -> app. transitions lose data
        var ATTR_COOKIE_NAME = 'audos_attr';
        
        function getAttrCookieDomain() {
          var hostname = window.location.hostname;
          var platformDomains = [
            'replit.dev', 'replit.app', 'repl.co',
            'github.io', 'herokuapp.com', 'netlify.app', 'vercel.app',
            'pages.dev', 'workers.dev', 'web.app', 'firebaseapp.com',
            'azurewebsites.net', 'cloudfront.net', 'amazonaws.com',
            'ngrok.io', 'ngrok.app', 'railway.app', 'render.com',
            'fly.dev', 'deno.dev', 'glitch.me'
          ];
          var isLocalhost = hostname === 'localhost' || hostname === '127.0.0.1' || hostname.endsWith('.localhost');
          var isIP = /^\d+\.\d+\.\d+\.\d+$/.test(hostname);
          var isPlatform = false;
          for (var i = 0; i < platformDomains.length; i++) {
            if (hostname.endsWith('.' + platformDomains[i]) || hostname === platformDomains[i]) {
              isPlatform = true;
              break;
            }
          }
          if (isLocalhost || isIP || isPlatform) return '';
          var parts = hostname.split('.');
          var lastTwo = parts.slice(-2).join('.');
          if (MULTI_LEVEL_TLDS.indexOf(lastTwo) !== -1 && parts.length >= 3) {
            return '; domain=.' + parts.slice(-3).join('.');
          } else if (parts.length >= 2) {
            return '; domain=.' + parts.slice(-2).join('.');
          }
          return '';
        }
        
        function setAttrCookie(jsonStr) {
          var isSecure = window.location.protocol === 'https:';
          var secureFlag = isSecure ? '; Secure' : '';
          document.cookie = ATTR_COOKIE_NAME + '=' + encodeURIComponent(jsonStr) + '; max-age=86400; path=/' + getAttrCookieDomain() + '; SameSite=Lax' + secureFlag;
        }
        
        function getAttrCookie() {
          var cookies = document.cookie.split(';');
          for (var i = 0; i < cookies.length; i++) {
            var c = cookies[i].trim();
            if (c.startsWith(ATTR_COOKIE_NAME + '=')) {
              try {
                return JSON.parse(decodeURIComponent(c.substring(ATTR_COOKIE_NAME.length + 1)));
              } catch (e) { return null; }
            }
          }
          return null;
        }
        
        function storeAttribution() {
          var params = new URLSearchParams(window.location.search);
          var hasTracking = params.get('fbclid') || params.get('gclid') || 
                            params.get('utm_source') || params.get('utm_campaign');
          
          if (hasTracking) {
            var attr = {
              utm_source: params.get('utm_source'),
              utm_medium: params.get('utm_medium'),
              utm_campaign: params.get('utm_campaign'),
              utm_content: params.get('utm_content'),
              utm_term: params.get('utm_term'),
              fbclid: params.get('fbclid'),
              gclid: params.get('gclid'),
              ref: params.get('ref'),
              capturedAt: new Date().toISOString()
            };
            setAttrCookie(JSON.stringify(attr));
            console.log('[Funnel] Attribution stored in cookie:', attr);
          }
        }
        
        function getStoredAttribution() {
          return getAttrCookie();
        }
        
        function getAttribution() {
          var params = new URLSearchParams(window.location.search);
          var current = {
            utm_source: params.get('utm_source'),
            utm_medium: params.get('utm_medium'),
            utm_campaign: params.get('utm_campaign'),
            utm_content: params.get('utm_content'),
            utm_term: params.get('utm_term'),
            fbclid: params.get('fbclid'),
            gclid: params.get('gclid'),
            ref: params.get('ref'),
          };
          
          var stored = getStoredAttribution();
          if (stored) {
            for (var key in stored) {
              if (!current[key] && stored[key] && key !== 'capturedAt') {
                current[key] = stored[key];
              }
            }
          }
          
          var filtered = {};
          for (var key in current) {
            if (current[key] !== null) {
              filtered[key] = current[key];
            }
          }
          
          return Object.keys(filtered).length > 0 ? filtered : null;
        }
        
        function __startFunnelTracking() {
          // Store attribution on first landing
          storeAttribution();
          
          // Track page view on load and link to recording
          window.addEventListener('DOMContentLoaded', function() {
            trackEvent('landing_page_view').then(function(data) {
              if (data && data.eventId && window.__RECORDING_ID__) {
                // Link the recording to this funnel event
                fetch('/api/crm/session-recordings/' + window.__RECORDING_ID__ + '/link', {
                  method: 'PATCH',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({ funnelEventId: data.eventId })
                }).then(function() {
                  console.log('[Funnel] Recording linked to event:', data.eventId);
                }).catch(function(e) {
                  console.error('[Funnel] Failed to link recording:', e);
                });
              }
            });
            console.log('[Funnel] Page view tracked for app:', appId);
            
            // Track clicks on CTA buttons
            document.addEventListener('click', function(e) {
              var target = e.target.closest('a, button');
              if (!target) return;
              
              var href = target.getAttribute('href') || '';
              var text = target.textContent || '';
              
              // Detect CTA clicks vs general link clicks (mutually exclusive to avoid double-counting)
              var lowerText = text.toLowerCase();
              if (href.includes('/workspace/') || href.includes('/bootup/') || 
                  lowerText.includes('get started') || 
                  lowerText.includes('sign up') ||
                  lowerText.includes('start') ||
                  lowerText.includes('try')) {
                trackEvent('landing_page_cta_click', { 
                  linkType: 'cta',
                  buttonText: text.substring(0, 50),
                  href: href.substring(0, 100)
                });
                console.log('[Funnel] CTA click tracked:', text);
              } else {
                trackEvent('link_click', {
                  linkUrl: href.substring(0, 200),
                  linkText: text.trim().substring(0, 100),
                  buttonText: text.trim().substring(0, 50)
                });
              }
            });

            // Scroll depth milestone tracking (25%, 50%, 75%, 100%)
            var scrollMilestones = {};
            var scrollThresholds = [25, 50, 75, 100];
            function checkScrollDepth() {
              var scrollTop = window.pageYOffset || document.documentElement.scrollTop;
              var docHeight = Math.max(
                document.body.scrollHeight, document.documentElement.scrollHeight,
                document.body.offsetHeight, document.documentElement.offsetHeight
              );
              var winHeight = window.innerHeight || document.documentElement.clientHeight;
              var scrollPercent = docHeight <= winHeight ? 100 : Math.round((scrollTop / (docHeight - winHeight)) * 100);
              for (var i = 0; i < scrollThresholds.length; i++) {
                var threshold = scrollThresholds[i];
                if (scrollPercent >= threshold && !scrollMilestones[threshold]) {
                  scrollMilestones[threshold] = true;
                  trackEvent('scroll_depth', { scrollDepth: threshold });
                  console.log('[Funnel] Scroll depth milestone:', threshold + '%');
                }
              }
            }
            var scrollTimer = null;
            window.addEventListener('scroll', function() {
              if (scrollTimer) clearTimeout(scrollTimer);
              scrollTimer = setTimeout(checkScrollDepth, 150);
            }, { passive: true });
            // Check initial scroll position (e.g. if page loaded scrolled)
            setTimeout(checkScrollDepth, 500);
          });
          
          // Expose generic tracking function for custom events
          window.trackFunnelEvent = trackEvent;
        }

        // trackEmailCapture is defined outside __startFunnelTracking so it is
        // always available regardless of GDPR analytics consent. Contact
        // creation from an explicit user form submission is not analytics.
        window.trackEmailCapture = function(email, callback) {
          var sessionId = getSessionId();
          fetch('/api/landing/' + appId + '/register', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              email: email,
              sessionId: sessionId,
              visitorId: visitorId,
              metadata: {},
              attribution: getAttribution()
            })
          }).then(function(res) {
            if (res.ok) {
              return res.json().then(function(data) {
                console.log('[Funnel] Email captured:', email, 'visitorId:', visitorId);
                if (data.sessionId) setSessionId(data.sessionId);
                if (data.contactId) setContactId(data.contactId);

                if (typeof fbq === 'function') {
                  fbq('track', 'Lead', {
                    content_name: 'Email Capture',
                    content_category: 'landing_page'
                  }, {
                    em: email.toLowerCase().trim()
                  });
                  console.log('[Funnel] Meta Pixel Lead event fired');
                }

                if (callback) callback(null, data);
              });
            } else {
              console.error('[Funnel] Failed to register email, status:', res.status);
              if (callback) callback(new Error('Registration failed'));
            }
          }).catch(function(err) {
            console.error('[Funnel] Failed to register email:', err);
            if (callback) callback(err);
          });
        };

        // Auto-capture: intercept form submissions that contain an email input
        // so landing page bundles that forget to call trackEmailCapture still
        // persist contacts to funnel_contacts.
        var __emailCaptured = {};
        document.addEventListener('submit', function(e) {
          var form = e.target;
          if (!form || form.tagName !== 'FORM') return;
          var emailInput = form.querySelector('input[type="email"], input[name="email"]');
          if (!emailInput) return;
          var email = (emailInput.value || '').trim().toLowerCase();
          if (!email || email.indexOf('@') === -1) return;
          if (__emailCaptured[email]) return;
          __emailCaptured[email] = true;
          window.trackEmailCapture(email);
          console.log('[Funnel] Auto-captured email from form submit:', email);
        }, true);

        __startFunnelTracking();
      })();
    </script>
    
    <script>
      // Referral tracking for landing pages
      (function() {
        const workspaceId = window.__WORKSPACE_ID__;
        if (!workspaceId) return;
        
        const REFERRAL_CODE_KEY = 'referral_code';
        const SESSION_ID_KEY = 'funnel_session_id';
        
        // Get session ID (reuse analytics session)
        function getSessionId() {
          let sessionId = sessionStorage.getItem(SESSION_ID_KEY);
          if (!sessionId) {
            sessionId = 'session_' + Date.now() + '_' + Math.random().toString(36).substring(7);
            sessionStorage.setItem(SESSION_ID_KEY, sessionId);
          }
          return sessionId;
        }
        
        // Capture referral code from URL
        function captureReferralCode() {
          const existingCode = sessionStorage.getItem(REFERRAL_CODE_KEY);
          if (existingCode) return existingCode;
          
          const urlParams = new URLSearchParams(window.location.search);
          const refCode = urlParams.get('ref');
          
          if (refCode) {
            sessionStorage.setItem(REFERRAL_CODE_KEY, refCode);
